# Cromwell OS — Development Environment
# Copy this file to .env:  cp .env.example .env
# These defaults work with `npx prisma dev` (embedded Postgres)

DATABASE_URL="postgres://postgres:postgres@localhost:51214/cromwell_os?sslmode=disable&connection_limit=10&connect_timeout=0"
SHADOW_DATABASE_URL="postgres://postgres:postgres@localhost:51215/cromwell_os_shadow?sslmode=disable&connection_limit=10&connect_timeout=0"
NEXTAUTH_SECRET="cromwell-os-dev-secret-change-in-production"
NEXTAUTH_URL="http://localhost:3000"

# Yapily Open Banking (optional — CSV import works without these)
YAPILY_APP_UUID=""
YAPILY_APP_SECRET=""
